# --- Required: one key runs everything ---
OPENAI_API_KEY=

# --- Optional: add providers, then change LLM_MODEL to use them ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Model selection (LiteLLM routes by name; swap freely) ---
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# --- Local storage (no servers) ---
QDRANT_PATH=./data/qdrant
DB_PATH=./data/app.db

# --- Limits / lifecycle ---
NOTEBOOK_TTL_HOURS=24
MAX_UPLOAD_MB=20
MAX_FILES=10